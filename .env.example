# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests.
# Add your React dev server and any production portal URLs here.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── API key (optional) ────────────────────────────────────────────────────────
# When set, clients must send:  X-API-Key: <value>
# Leave empty to disable API-key authentication.
API_KEY=

# ── Embodied carbon cache ────────────────────────────────────────────────────
# Refreshes data/embodied.json on API startup when missing or older than the
# configured age. Disable if startup must be fully offline.
EMBODIED_REFRESH_ENABLED=true
EMBODIED_REFRESH_MAX_AGE_DAYS=7

# ── AWS credentials ───────────────────────────────────────────────────────────
# Leave blank to use the boto3 default credential chain
# (environment variables, ~/.aws/credentials, IAM role, etc.)
AWS_DEFAULT_REGION=eu-west-1
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── CCFT account filter (optional) ───────────────────────────────────────────
# Set to a 12-digit AWS account ID to restrict CCFT emissions data to a single
# linked account. Leave empty to return data across all accounts (default when
# called from a management/payer account).
AWS_CCFT_ACCOUNT_ID=
