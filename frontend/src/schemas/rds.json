{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "rds",
  "description": "Fields required to estimate the carbon footprint and cost of an RDS database instance.",
  "type": "object",
  "required": ["instance_class", "engine", "storage_gb", "region"],
  "properties": {
    "instance_class": {
      "type": "string",
      "title": "Instance Class",
      "description": "RDS instance class.",
      "enum": [
        "db.t3.micro",
        "db.t3.small",
        "db.t3.medium",
        "db.t3.large",
        "db.t3.xlarge",
        "db.t3.2xlarge",
        "db.t4g.micro",
        "db.t4g.small",
        "db.t4g.medium",
        "db.t4g.large",
        "db.t4g.xlarge",
        "db.t4g.2xlarge",
        "db.m5.large",
        "db.m5.xlarge",
        "db.m5.2xlarge",
        "db.m5.4xlarge",
        "db.m5.8xlarge",
        "db.m5.12xlarge",
        "db.m5.16xlarge",
        "db.m5.24xlarge",
        "db.m6g.large",
        "db.m6g.xlarge",
        "db.m6g.2xlarge",
        "db.m6g.4xlarge",
        "db.m6g.8xlarge",
        "db.m6g.12xlarge",
        "db.m6g.16xlarge",
        "db.m6i.large",
        "db.m6i.xlarge",
        "db.m6i.2xlarge",
        "db.m6i.4xlarge",
        "db.m6i.8xlarge",
        "db.c5.large",
        "db.c5.xlarge",
        "db.c5.2xlarge",
        "db.c5.4xlarge",
        "db.c5.9xlarge",
        "db.c5.18xlarge",
        "db.c6g.large",
        "db.c6g.xlarge",
        "db.c6g.2xlarge",
        "db.c6g.4xlarge",
        "db.c6g.8xlarge",
        "db.c6g.12xlarge",
        "db.c6g.16xlarge",
        "db.c6i.large",
        "db.c6i.xlarge",
        "db.c6i.2xlarge",
        "db.c6i.4xlarge",
        "db.r5.large",
        "db.r5.xlarge",
        "db.r5.2xlarge",
        "db.r5.4xlarge",
        "db.r5.8xlarge",
        "db.r5.12xlarge",
        "db.r5.16xlarge",
        "db.r5.24xlarge",
        "db.r6g.large",
        "db.r6g.xlarge",
        "db.r6g.2xlarge",
        "db.r6g.4xlarge",
        "db.r6g.8xlarge",
        "db.r6g.12xlarge",
        "db.r6g.16xlarge",
        "db.r6i.large",
        "db.r6i.xlarge",
        "db.r6i.2xlarge",
        "db.r6i.4xlarge",
        "db.r6i.8xlarge"
      ]
    },
    "engine": {
      "type": "string",
      "title": "Database Engine",
      "description": "RDS database engine.",
      "enum": [
        "mysql",
        "postgres",
        "mariadb",
        "oracle-ee",
        "oracle-se2",
        "sqlserver-ex",
        "sqlserver-web",
        "sqlserver-se",
        "sqlserver-ee",
        "aurora-mysql",
        "aurora-postgresql"
      ],
      "enumNames": [
        "MySQL",
        "PostgreSQL",
        "MariaDB",
        "Oracle Enterprise Edition",
        "Oracle Standard Edition Two",
        "SQL Server Express",
        "SQL Server Web",
        "SQL Server Standard",
        "SQL Server Enterprise",
        "Aurora (MySQL compatible)",
        "Aurora (PostgreSQL compatible)"
      ]
    },
    "storage_gb": {
      "type": "number",
      "title": "Allocated Storage (GB)",
      "description": "Allocated storage in gigabytes.",
      "minimum": 20,
      "maximum": 65536
    },
    "region": {
      "type": "string",
      "title": "AWS Region",
      "description": "AWS region where the instance will run.",
      "enum": [
        "us-east-1",
        "us-east-2",
        "us-west-1",
        "us-west-2",
        "us-gov-east-1",
        "us-gov-west-1",
        "ca-central-1",
        "ca-west-1",
        "eu-west-1",
        "eu-west-2",
        "eu-west-3",
        "eu-central-1",
        "eu-central-2",
        "eu-north-1",
        "eu-south-1",
        "eu-south-2",
        "ap-east-1",
        "ap-east-2",
        "ap-southeast-1",
        "ap-southeast-2",
        "ap-southeast-3",
        "ap-southeast-4",
        "ap-southeast-5",
        "ap-southeast-6",
        "ap-southeast-7",
        "ap-northeast-1",
        "ap-northeast-2",
        "ap-northeast-3",
        "ap-south-1",
        "ap-south-2",
        "sa-east-1",
        "il-central-1",
        "me-south-1",
        "me-central-1",
        "mx-central-1",
        "af-south-1"
      ]
    }
  },
  "additionalProperties": false
}
